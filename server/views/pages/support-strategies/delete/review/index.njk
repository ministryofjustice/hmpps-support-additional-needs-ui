{% extends "../../layout.njk" %}

{% set pageId = 'delete-support-strategy-review' %}
{% set pageTitle = applicationName + ' - ' + ('Delete history support strategy review' if mode == 'history' else 'Delete support strategy review') %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-l">Review the {% if mode == 'history' %}history {% endif %}support strategy for {{ prisonerSummary | formatFirst_name_Last_name }} that you want to delete</h1>

      <div class="govuk-summary-card app-summary-card--grey govuk-!-margin-bottom-8" data-qa="support-strategy-to-delete-summary">
        <div class="govuk-summary-card__content">
          <p class="govuk-body app-u-multiline-text govuk-!-margin-bottom-0" data-qa="support-strategy-to-delete-details">{{ dto.supportStrategyDetails }}</p>
        </div>
      </div>

      <form class="form" method="post" novalidate="">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

        {{ govukButton({
          id: "submit-button",
          text: "Continue",
          type: "submit",
          attributes: {"data-qa": "submit-button"},
          preventDoubleClick: true
        }) }}
      </form>
    </div>
  </div>
{% endblock %}
